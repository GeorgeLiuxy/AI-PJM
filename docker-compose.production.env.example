# Copy this file to .env.production.local and replace every placeholder before
# using it outside a local smoke test. Do not commit real secrets.

AI_PJM_IMAGE_TAG=local

POSTGRES_USER=ai_pjm
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=ai_pjm

AUTH_ENABLED=true
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-admin-password
AUTH_BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrator
AUTH_BOOTSTRAP_PROJECT_KEY=default
AUTH_BOOTSTRAP_PROJECT_NAME=Default Project

SECRET_STORE_MASTER_KEY=replace-with-long-random-secret-at-least-32-chars
SECRET_STORE_KEY_ID=production

FRONTEND_PORT=8080
BACKEND_PORT=8010
DELIVERY_APP_BASE_URL=http://localhost:8080
CORS_ORIGINS=["http://localhost:8080"]
AI_PJM_WORKSPACE_MOUNT=.
WORKSPACE_ROOT=/workspace
EXECUTION_WORKTREE_ROOT=/workspace/.runtime/worktrees

LOG_LEVEL=INFO
LOG_FORMAT=json

EXECUTION_CODEX_ENABLED=false
EXECUTION_CODEX_COMMAND_TEMPLATE=
EXECUTION_CODEX_PREFLIGHT_COMMAND=
EXECUTION_CODEX_TIMEOUT_SECONDS=1800
EXECUTION_AUTO_REPAIR_MAX_ATTEMPTS=1
EXECUTION_MAX_CONCURRENCY=1

MERGE_REQUEST_DEFAULT_TARGET_BRANCH=main
MERGE_REQUEST_AUTO_PUSH_ENABLED=true
MERGE_REQUEST_GIT_REMOTE=origin

GITLAB_API_BASE_URL=
GITLAB_PROJECT_ID=
GITLAB_TOKEN=
GITLAB_TOKEN_SECRET_NAME=gitlab_token
GITLAB_DEFAULT_LABELS=
GITLAB_REVIEWER_IDS=
GITLAB_ASSIGNEE_IDS=
GITLAB_WEBHOOK_SECRET_TOKEN=

GITHUB_API_BASE_URL=https://api.github.com
GITHUB_REPOSITORY=
GITHUB_TOKEN=
GITHUB_TOKEN_SECRET_NAME=github_token
GITHUB_DEFAULT_LABELS=
GITHUB_REVIEWERS=
GITHUB_ASSIGNEES=
GITHUB_WEBHOOK_SECRET=

DEPLOY_WEBHOOK_URL=
DEPLOY_TOKEN=
DEPLOY_TOKEN_SECRET_NAME=deploy_token
DEPLOY_ENVIRONMENT_CONFIG_JSON=
DEPLOYMENT_SYNC_LIMIT=20
DEPLOYMENT_SYNC_POLL_SECONDS=120

SYMPHONY_BRIDGE_TOKEN=
SYMPHONY_BRIDGE_DEFAULT_LEASE_SECONDS=300
SYMPHONY_WORKER_ID=compose-worker-1
SYMPHONY_RUNNER_COMMAND=
SYMPHONY_WORKER_COMMAND_TIMEOUT_SECONDS=1800
SYMPHONY_WORKER_LEASE_SECONDS=2100
SYMPHONY_WORKER_POLL_SECONDS=5

AI_PJM_API_TOKEN=
OBSERVABILITY_ALERT_WEBHOOK_URL=
OBSERVABILITY_ALERT_POLL_SECONDS=120

AI_WORKFLOW_PROVIDER=local
AI_WORKFLOW_PROVIDER_FALLBACK_ENABLED=true

OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_API_KEY_SECRET_NAME=openai_api_key
OPENAI_MODEL=gpt-4o-mini

DIFY_API_BASE_URL=
DIFY_API_KEY=
DIFY_API_KEY_SECRET_NAME=dify_api_key
DIFY_SPEC_WORKFLOW_ID=
DIFY_IMPACT_WORKFLOW_ID=
DIFY_HEALTH_CHECK_URL=
