# Application
APP_NAME=AI PJM Backend
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_pjm
DATABASE_ECHO=false

# Redis (reserved for future use)
REDIS_URL=redis://localhost:6379/0

# Celery (reserved for future use)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AI API (reserved for future use)
# ANTHROPIC_API_KEY=your_key_here

# CORS
CORS_ORIGINS=["http://localhost:5174", "http://localhost:5173"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
