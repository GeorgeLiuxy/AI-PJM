# Application
APP_NAME=AI PJM Backend
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8010

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/ai_pjm_dev.db
DATABASE_ECHO=false

# Delivery execution
WORKSPACE_ROOT=
EXECUTION_COMMAND_TIMEOUT_SECONDS=120

# AI workflow providers
AI_WORKFLOW_PROVIDER=mock
DIFY_API_BASE_URL=
DIFY_API_KEY=
DIFY_SPEC_WORKFLOW_ID=
DIFY_IMPACT_WORKFLOW_ID=
# ANTHROPIC_API_KEY=your_key_here

# CORS
CORS_ORIGINS=["http://localhost:5174", "http://localhost:5173"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
