# Application
APP_NAME=AI PJM Backend
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8010
DELIVERY_APP_BASE_URL=http://127.0.0.1:5174

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/ai_pjm_dev.db
DATABASE_ECHO=false
DATABASE_VALIDATE_MIGRATIONS=true

# Auth and project access
# Development keeps auth disabled by default. Production must set AUTH_ENABLED=true
# and provide AUTH_BOOTSTRAP_ADMIN_PASSWORD on first startup.
AUTH_ENABLED=false
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=
AUTH_BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrator
AUTH_BOOTSTRAP_PROJECT_KEY=default
AUTH_BOOTSTRAP_PROJECT_NAME=Default Project

# Secret store
# Required before storing project credentials. Use a long random value and keep
# it outside source control.
SECRET_STORE_MASTER_KEY=
SECRET_STORE_KEY_ID=local

# Delivery execution
WORKSPACE_ROOT=
EXECUTION_WORKTREE_ROOT=
EXECUTION_COMMAND_TIMEOUT_SECONDS=120
EXECUTION_CODEX_ENABLED=false
EXECUTION_CODEX_PREFLIGHT_COMMAND=codex --version
EXECUTION_CODEX_PREFLIGHT_TIMEOUT_SECONDS=30
EXECUTION_CODEX_COMMAND_TEMPLATE=powershell -NoProfile -ExecutionPolicy Bypass -File "{original_workspace_root}\scripts\run-codex-task.ps1" -PromptFile "{prompt_file}" -WorkspaceRoot "{workspace_root}"
EXECUTION_CODEX_TIMEOUT_SECONDS=1800
EXECUTION_AUTO_REPAIR_MAX_ATTEMPTS=1
EXECUTION_MAX_CONCURRENCY=1
MERGE_REQUEST_DEFAULT_TARGET_BRANCH=main
MERGE_REQUEST_AUTO_PUSH_ENABLED=true
MERGE_REQUEST_GIT_REMOTE=origin
MERGE_REQUEST_PUSH_TIMEOUT_SECONDS=120
GITLAB_API_BASE_URL=
GITLAB_PROJECT_ID=
GITLAB_TOKEN=
GITLAB_TOKEN_SECRET_NAME=gitlab_token
GITLAB_DEFAULT_LABELS=
GITLAB_REVIEWER_IDS=
GITLAB_ASSIGNEE_IDS=
GITLAB_WEBHOOK_SECRET_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_REPOSITORY=
GITHUB_TOKEN=
GITHUB_TOKEN_SECRET_NAME=github_token
GITHUB_DEFAULT_LABELS=
GITHUB_REVIEWERS=
GITHUB_ASSIGNEES=
GITHUB_WEBHOOK_SECRET=
DEPLOY_WEBHOOK_URL=
DEPLOY_TOKEN=
DEPLOY_TOKEN_SECRET_NAME=deploy_token

# Symphony Bridge API
# Set a non-empty token to enable the internal Symphony Bridge endpoints. The
# worker must send the same value in X-Symphony-Bridge-Token.
SYMPHONY_BRIDGE_TOKEN=
SYMPHONY_BRIDGE_DEFAULT_LEASE_SECONDS=300

# Observability
OBSERVABILITY_QUEUE_BACKLOG_THRESHOLD=5
OBSERVABILITY_ALERT_SAMPLE_LIMIT=5
OBSERVABILITY_FAILURE_RATE_WINDOW_MINUTES=60
OBSERVABILITY_FAILURE_RATE_MIN_RUNS=10
OBSERVABILITY_FAILURE_RATE_THRESHOLD_PERCENT=40

# Symphony Bridge worker
# These values are read by backend/scripts/symphony_worker.py when running the
# optional local worker. CLI flags with the same names take precedence.
AI_PJM_API_BASE_URL=http://127.0.0.1:8010/api/v2
SYMPHONY_WORKER_ID=
SYMPHONY_WORKSPACE=
SYMPHONY_WORKER_RUNTIME_DIR=.runtime/symphony-worker
SYMPHONY_WORKER_STATUS_FILE=.runtime/symphony-worker/worker-status.json
SYMPHONY_RUNNER_COMMAND=
SYMPHONY_WORKER_COMMAND_TIMEOUT_SECONDS=1800
SYMPHONY_WORKER_LEASE_SECONDS=2100
SYMPHONY_WORKER_POLL_SECONDS=5

# AI workflow providers
AI_WORKFLOW_PROVIDER=local
OPENAI_API_KEY=
OPENAI_API_KEY_SECRET_NAME=openai_api_key
DIFY_API_BASE_URL=
DIFY_API_KEY=
DIFY_API_KEY_SECRET_NAME=dify_api_key
DIFY_SPEC_WORKFLOW_ID=
DIFY_IMPACT_WORKFLOW_ID=
# ANTHROPIC_API_KEY=your_key_here

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:5174", "http://localhost:5175", "http://localhost:5176", "http://127.0.0.1:5173", "http://127.0.0.1:5174", "http://127.0.0.1:5175", "http://127.0.0.1:5176"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=text
