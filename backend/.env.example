# Application
APP_NAME=AI PJM Backend
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8010

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/ai_pjm_dev.db
DATABASE_ECHO=false

# Auth and project access
# Development keeps auth disabled by default. Production must set AUTH_ENABLED=true
# and provide AUTH_BOOTSTRAP_ADMIN_PASSWORD on first startup.
AUTH_ENABLED=false
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=
AUTH_BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrator
AUTH_BOOTSTRAP_PROJECT_KEY=default
AUTH_BOOTSTRAP_PROJECT_NAME=Default Project

# Delivery execution
WORKSPACE_ROOT=
EXECUTION_WORKTREE_ROOT=
EXECUTION_COMMAND_TIMEOUT_SECONDS=120
EXECUTION_CODEX_ENABLED=false
EXECUTION_CODEX_PREFLIGHT_COMMAND=codex --version
EXECUTION_CODEX_PREFLIGHT_TIMEOUT_SECONDS=30
EXECUTION_CODEX_COMMAND_TEMPLATE=powershell -NoProfile -ExecutionPolicy Bypass -File "{original_workspace_root}\scripts\run-codex-task.ps1" -PromptFile "{prompt_file}" -WorkspaceRoot "{workspace_root}"
EXECUTION_CODEX_TIMEOUT_SECONDS=1800
EXECUTION_AUTO_REPAIR_MAX_ATTEMPTS=1
EXECUTION_MAX_CONCURRENCY=1
MERGE_REQUEST_DEFAULT_TARGET_BRANCH=main

# AI workflow providers
AI_WORKFLOW_PROVIDER=local
DIFY_API_BASE_URL=
DIFY_API_KEY=
DIFY_SPEC_WORKFLOW_ID=
DIFY_IMPACT_WORKFLOW_ID=
# ANTHROPIC_API_KEY=your_key_here

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:5174", "http://localhost:5175", "http://localhost:5176", "http://127.0.0.1:5173", "http://127.0.0.1:5174", "http://127.0.0.1:5175", "http://127.0.0.1:5176"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
